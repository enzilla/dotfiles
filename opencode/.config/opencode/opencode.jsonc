{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": "notify",
  "snapshot": true,
  "default_agent": "workbench",
  "instructions": ["~/.config/opencode/AGENTS.md"],
  "skills": {
    "paths": ["~/.config/opencode/skills"]
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "stow -n*": "allow",
      "stow --simulate*": "allow",
      "rm *": "deny",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "deny",
      "curl *": "ask",
      "wget *": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.config/opencode/auth*": "deny",
      "~/.config/opencode/session/**": "deny"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "explore": {
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": false,
      "timeout": 15000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": false,
      "timeout": 15000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false,
      "timeout": 15000
    }
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.next/**",
      "**/dist/**",
      "**/build/**",
      "**/.venv/**",
      "**/target/**"
    ]
  },
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 24000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 8
  },
  "experimental": {
    "mcp_timeout": 15000
  }
}
