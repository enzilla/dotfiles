{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": "notify",
  "snapshot": true,
  "plugin": ["@dietrichgebert/ponytail"],
  "default_agent": "workbench",
  "instructions": ["~/.config/opencode/AGENTS.md"],
  "skills": {
    "paths": ["~/.config/opencode/skills"]
  },
  "permission": "allow",
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    },
    "explore": {
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": false,
      "timeout": 15000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": false,
      "timeout": 15000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false,
      "timeout": 15000
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=fwynwflbjymhrvzncffj",
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.next/**",
      "**/dist/**",
      "**/build/**",
      "**/.venv/**",
      "**/target/**"
    ]
  },
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 24000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 8
  },
  "experimental": {
    "mcp_timeout": 15000
  }
}
