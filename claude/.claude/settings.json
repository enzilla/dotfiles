{
  "includeCoAuthoredBy": false,
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/home/enzo/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/enzo/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "erp@numih": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "numih": {
      "source": {
        "source": "github",
        "repo": "Numih/cursor",
        "path": "/home/enzo/dev/modulos/cursor"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "theme": "dark"
}
